# Server
PORT=3000

# Avito credentials
AVITO_LOGIN=your_avito_phone_or_email
AVITO_PASSWORD=your_avito_password

# Target sender name to monitor (partial match, case-insensitive)
AVITO_TARGET_SENDER=Рушан

# Puppeteer settings
PUPPETEER_HEADLESS=true
PUPPETEER_SLOW_MO=0

# Message polling interval in milliseconds
POLLING_INTERVAL_MS=5000

# Cloudflared tunnel URL (set after tunnel starts)
TUNNEL_URL=
